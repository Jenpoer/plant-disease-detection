{
    "model_name": "swin_base_patch4_window7_224",
    "data_dir": ".",
    "splits_dir": "data/splits",
    "checkpoint_dir": "checkpoints/augmented_random_crop_resize",

    "hyperparameters": {
        "batch_size": 32,
        "num_epochs": 10,
        "learning_rate": 0.0001
    },

    "transformations": {
      "steps": [
        {
          "name": "random_resized_crop",
          "params": {
            "size": 224, "scale": [0.8, 1.0], "ratio": [0.9, 1.1]
          }
        },
        {
          "name": "color_jitter",
          "params": {
            "brightness": 0.2, "contrast": 0.2, "saturation": 0.2, "hue": 0.05
          }
        }
      ]
  }
}
