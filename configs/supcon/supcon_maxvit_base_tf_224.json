{
    "model_name": "maxvit_base_tf_224",
    "data_dir": "../plant-disease-detection",
    "splits_dir": "../plant-disease-detection/data/splits",
    "checkpoint_dir": "checkpoints/dg",

    "hyperparameters": {
        "batch_size": 32,
        "num_epochs": 20,
        "learning_rate": 0.001
    },

    "transformations": [
        {
            "name": "random_rotation",
            "params": {
                "degrees": 8
            }
        },
        {
            "name": "gaussian_blur",
            "params": {
                "kernel_size": 3,
                "sigma": [
                    0.1,
                    0.8
                ]
            }
        },
        {
            "name": "random_perspective",
            "params": {
                "distortion_scale": 0.2,
                "p": 0.3,
                "fill": 0
            }
        },
        {
            "name": "random_erasing",
            "params": {
                "p": 0.15,
                "scale": [
                    0.02,
                    0.08
                ],
                "ratio": [
                    0.3,
                    3.3
                ],
                "value": 0,
                "inplace": false
            }
        },
        {
            "name": "random_affine",
            "params": {
                "translate": [
                    0.1,
                    0.1
                ],
                "scale": [
                    0.85,
                    1.15
                ],
                "shear": 10
            }
        }
    ]
}